          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/resources/:id/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "resources", ":id", "reject"],
