                {
                  "key": "id",
                  "value": "resource-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Toggle Resource Active",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/resources/:id/toggle",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "resources", ":id", "toggle"],
              "variable": [
                {
                  "key": "id",
                  "value": "resource-id-here"
                }
              ]
            }
