{
  "info": {
    "name": "Resource Center API",
    "description": "Колекція для тестування RESTful та GraphQL API Ресурсного центру",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth - RESTful",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Тест\",\n  \"lastName\": \"Користувач\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Resources - RESTful",
      "item": [
        {
          "name": "Get All Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Get Resources by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources?category=education",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources"],
              "query": [
                {"key": "category", "value": "education"}
              ]
            }
          }
        },
        {
          "name": "Search Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources?search=programming",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources"],
              "query": [
                {"key": "search", "value": "programming"}
              ]
            }
          }
        },
        {
          "name": "Get Single Resource",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources", ":id"],
              "variable": [
                {"key": "id", "value": "RESOURCE_ID_HERE"}
              ]
            }
          }
        },
        {
          "name": "Create Resource",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Новий ресурс\",\n  \"description\": \"Опис нового ресурсу для тестування\",\n  \"category\": \"education\",\n  \"tags\": [\"тест\", \"навчання\"],\n  \"url\": \"https://example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/resources",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources"]
            }
          }
        },
        {
          "name": "Update Resource",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Оновлений ресурс\",\n  \"description\": \"Оновлений опис ресурсу\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/resources/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources", ":id"],
              "variable": [
                {"key": "id", "value": "RESOURCE_ID_HERE"}
              ]
            }
          }
        },
        {
          "name": "Delete Resource",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/resources/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources", ":id"],
              "variable": [
                {"key": "id", "value": "RESOURCE_ID_HERE"}
              ]
            }
          }
        },
        {
          "name": "Get My Resources",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/resources/user/my-resources",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources", "user", "my-resources"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - RESTful",
      "item": [
        {
          "name": "Get Admin Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "stats"]
            }
          }
        },
        {
          "name": "Get All Resources (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/resources?status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "resources"],
              "query": [
                {"key": "status", "value": "pending"}
              ]
            }
          }
        },
        {
          "name": "Approve Resource",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/resources/:id/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "resources", ":id", "approve"],
              "variable": [
                {"key": "id", "value": "RESOURCE_ID_HERE"}
              ]
            }
          }
        },
        {
          "name": "Reject Resource",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/resources/:id/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "resources", ":id", "reject"],
              "variable": [
                {"key": "id", "value": "RESOURCE_ID_HERE"}
              ]
            }
          }
        },
        {
          "name": "Toggle Resource Active",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/resources/:id/toggle-active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "resources", ":id", "toggle-active"],
              "variable": [
                {"key": "id", "value": "RESOURCE_ID_HERE"}
              ]
            }
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Toggle User Active",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/:id/toggle-active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", ":id", "toggle-active"],
              "variable": [
                {"key": "id", "value": "USER_ID_HERE"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "Get Resources (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { resources(filter: { page: 1, limit: 10 }) { success resources { id title description category author { firstName lastName } createdAt } total pages } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Get Single Resource (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { resource(id: \\\"RESOURCE_ID_HERE\\\") { success resource { id title description category tags url views } } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Register (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { register(input: { firstName: \\\"Тест\\\", lastName: \\\"Користувач\\\", email: \\\"test@example.com\\\", password: \\\"password123\\\" }) { success message user { id firstName lastName email } } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Login (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { login(input: { email: \\\"test@example.com\\\", password: \\\"password123\\\" }) { success message token user { id firstName lastName email role } } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Create Resource (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { createResource(input: { title: \\\"Новий ресурс GraphQL\\\", description: \\\"Опис ресурсу\\\", category: \\\"technology\\\", tags: [\\\"graphql\\\", \\\"api\\\"] }) { success message resource { id title } } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Admin Stats (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { adminStats { success totalUsers activeUsers totalResources approvedResources pendingResources } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          }
        }
      ]
    }
  ]
}
