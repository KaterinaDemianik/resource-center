		{
			"name": "GraphQL",
			"item": [
				{
					"name": "GraphQL - Get Resources",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"query GetResources($filter: ResourceFilterInput) { resources(filter: $filter) { success resources { id title description category author { firstName lastName } isActive isApproved createdAt } total page pages } }\",\n  \"variables\": {\n    \"filter\": {\n      \"category\": \"education\",\n      \"search\": \"навчання\",\n      \"page\": 1,\n      \"limit\": 10\n    }\n  }\n}"
						},
						"url": {
							"raw": "http://localhost:5001/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5001",
							"path": ["graphql"]
						},
						"description": "GraphQL запит для отримання ресурсів з фільтрацією"
					}
				},
				{
					"name": "GraphQL - Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"mutation Register($input: RegisterInput!) { register(input: $input) { success message token user { id firstName lastName email } } }\",\n  \"variables\": {\n    \"input\": {\n      \"firstName\": \"Марія\",\n      \"lastName\": \"Коваленко\",\n      \"email\": \"maria.kovalenko@gmail.com\",\n      \"password\": \"password123\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "http://localhost:5001/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5001",
							"path": ["graphql"]
						},
						"description": "GraphQL мутація для реєстрації користувача"
					}
				},
				{
					"name": "GraphQL - Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"mutation Login($input: LoginInput!) { login(input: $input) { success message token user { id firstName lastName email role } } }\",\n  \"variables\": {\n    \"input\": {\n      \"email\": \"admin@example.com\",\n      \"password\": \"password123\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "http://localhost:5001/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5001",
							"path": ["graphql"]
						},
						"description": "GraphQL мутація для авторизації"
					}
				},
				{
					"name": "GraphQL - Create Resource",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"mutation CreateResource($input: ResourceInput!) { createResource(input: $input) { success message resource { id title description category } } }\",\n  \"variables\": {\n    \"input\": {\n      \"title\": \"Онлайн курси програмування\",\n      \"description\": \"Безкоштовні курси для початківців\",\n      \"category\": \"education\",\n      \"tags\": [\"програмування\", \"курси\", \"навчання\"],\n      \"url\": \"https://example.com/courses\"\n    }\n  }\n}"
						},
						"url": {
							"raw": "http://localhost:5001/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5001",
							"path": ["graphql"]
						},
						"description": "GraphQL мутація для створення ресурсу"
					}
				},
				{
					"name": "GraphQL - Get Single Resource",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
